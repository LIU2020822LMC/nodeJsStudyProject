# 默认忽略的文件
/shelf/
/workspace.xml
# 基于编辑器的 HTTP 客户端请求
/httpRequests/
# Datasource local storage ignored files
/dataSources/
/dataSources.local.xml
# 依赖包
/node_modules/

# 环境变量（绝对不能推！）
.env
.env.local
.env.*.local

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 构建产物
/dist/
/build/
/out/

# IDE 配置（你之前已经加了，这里补充完整）
.idea/
.vscode/
*.swp
*.swo
*~

# 系统自动生成的文件
.DS_Store
Thumbs.db
