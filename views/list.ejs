<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>记账本</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: "Microsoft Yahei", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }
        /* 科幻背景：深色渐变 + 科技网格纹理（和添加记录页统一） */
        body {
            padding: 25px 35px;
            min-height: 100vh;
            background: linear-gradient(135deg, #0a0e27 0%, #1a237e 50%, #283593 100%);
            background-image:
                    linear-gradient(rgba(10, 14, 39, 0.7) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(10, 14, 39, 0.7) 1px, transparent 1px),
                    linear-gradient(135deg, #0a0e27 0%, #1a237e 50%, #283593 100%);
            background-size: 30px 30px, 30px 30px, cover;
        }
        /* 科幻标题：霓虹发光 + 科技边框 */
        .page-title {
            font-size: 3em;
            color: #00d4ff;
            font-weight: normal;
            margin-bottom: 35px;
            padding-bottom: 22px;
            border-bottom: 1px solid rgba(0, 212, 255, 0.3);
            text-shadow:
                    0 0 10px #00d4ff,
                    0 0 20px #00d4ff,
                    0 0 30px #0099cc;
            letter-spacing: 2px;
        }
        /* 账单卡片：毛玻璃效果 + 霓虹发光边框 */
        .record-card {
            border: 1px solid rgba(0, 212, 255, 0.4);
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 28px;
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(10px);
            box-shadow: 0 0 20px rgba(0, 212, 255, 0.15);
            transition: all 0.3s ease;
        }
        /* 卡片悬浮：轻微上浮 + 增强发光 */
        .record-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 30px rgba(0, 212, 255, 0.3);
        }
        /* 日期栏：科幻霓虹配色 + 发光效果 */
        .record-date-bar {
            padding: 16px 22px;
            font-size: 1.4em;
            font-weight: 500;
            text-shadow: 0 0 5px rgba(255,255,255,0.3);
        }
        /* 支出：霓虹红 */
        .record-date-bar.expense {
            background: linear-gradient(90deg, #ff4757, #ff3742);
            color: #ffffff;
            box-shadow: inset 0 0 10px rgba(255, 71, 87, 0.5);
        }
        /* 收入：霓虹绿 */
        .record-date-bar.income {
            background: linear-gradient(90deg, #2ed573, #1dd19f);
            color: #ffffff;
            box-shadow: inset 0 0 10px rgba(46, 213, 115, 0.5);
        }
        /* 卡片内容区：半透明科幻背景 */
        .record-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 22px;
            background: rgba(255, 255, 255, 0.03);
        }
        .record-left {
            display: flex;
            align-items: center;
            gap: 25px;
        }
        /* 事项描述：科技蓝白色 */
        .record-desc {
            font-size: 1.5em;
            color: #e0f7ff;
            text-shadow: 0 0 3px rgba(0, 212, 255, 0.3);
        }
        /* 类型标签：霓虹发光效果 */
        .record-type-tag {
            padding: 6px 14px;
            border-radius: 4px;
            color: #ffffff;
            font-size: 1.05em;
            font-weight: 500;
            box-shadow: 0 0 8px currentColor;
        }
        .record-type-tag.expense {
            background: linear-gradient(90deg, #ffa726, #ff9800);
        }
        .record-type-tag.income {
            background: linear-gradient(90deg, #4caf50, #2e7d32);
        }
        /* 金额：荧光蓝 */
        .record-amount {
            font-size: 1.5em;
            color: #00d4ff;
            text-shadow: 0 0 8px rgba(0, 212, 255, 0.6);
            margin-right: 15px;
        }
        /* 删除按钮：科幻霓虹红 + 发光动画 */
        .delete-btn {
            display: inline-block;
            width: 30px;
            height: 30px;
            line-height: 28px;
            text-align: center;
            border-radius: 50%;
            background: linear-gradient(90deg, #ff4757, #ff3742);
            color: #ffffff;
            font-size: 16px;
            text-decoration: none;
            font-weight: bold;
            box-shadow: 0 0 10px rgba(255, 71, 87, 0.6);
            transition: all 0.2s ease;
        }
        .delete-btn:hover {
            transform: scale(1.15);
            box-shadow: 0 0 15px rgba(255, 71, 87, 0.9);
        }
        /* 添加账单按钮：霓虹蓝渐变 + 脉冲发光 */
        .btn-primary {
            color: #0a0e27;
            background: linear-gradient(90deg, #00d4ff 0%, #0099cc 100%);
            text-align: center;
            line-height: 50px;
            width: 110px;
            height: 50px;
            cursor: pointer;
            font-size: 20px;
            font-weight: bolder;
            text-decoration: none;
            border-radius: 5px;
            box-shadow: 0 0 15px rgba(0, 212, 255, 0.5);
            transition: all 0.3s ease;
            border: none;
        }
        .btn-primary:hover {
            background: linear-gradient(90deg, #00e5ff 0%, #00b3e6 100%);
            box-shadow: 0 0 25px rgba(0, 212, 255, 0.8);
            transform: translateY(-2px);
        }
        .btn-primary:active {
            transform: translateY(0);
            box-shadow: 0 0 10px rgba(0, 212, 255, 0.6);
        }
    </style>
</head>
<body>
<div style="display: flex; align-items: center; justify-content: space-between;">
    <h1 class="page-title">记账本</h1>
    <a  href="/account/create" class="btn-primary">添加账单</a>
</div>
<% accounts.forEach(item=> { %>
    <div class="record-card">
        <div class="record-date-bar <%= item.type === -1 ? 'expense' : 'income'%>"><%= moment(item.time).format('YYYY-MM-DD') %></div>
        <div class="record-content">
            <div class="record-left">
                <div class="record-desc"><%= item.title %></div>
                <div class="record-type-tag <%= item.type === -1 ? 'expense' : 'income'%>"><%= item.type === -1 ? '支出' : '收入'%></div>
            </div>
            <!-- 金额 + 删除X号 -->
            <div style="display: flex; align-items: center;">
                <div class="record-amount"><%= item.account %> 元</div>
                <!-- 按照图片写法的删除a标签 -->
                <a  href="/account/<%= item._id %>" class="delete-btn">X</a>
            </div>
        </div>
    </div>
<%  })%>

<script>
    const delBtns = document.querySelectorAll('.delete-btn');
    delBtns.forEach(item=>{
        item.addEventListener('click',(e)=>{
            if(confirm('你确定要删除该条记录吗？')){
                return true
            }else {
                e.preventDefault()
            }
        })
    })


</script>
</body>
</html>