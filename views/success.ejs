<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>添加成功</title>
    <!-- 引入图标字体（可选，增强美观度） -->
    <link rel="stylesheet" href="https://cdn.bootcdn.net/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Microsoft Yahei", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        /* 统一科幻背景：深色渐变 + 科技网格纹理 */
        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #0a0e27 0%, #1a237e 50%, #283593 100%);
            background-image:
                    linear-gradient(rgba(10, 14, 39, 0.7) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(10, 14, 39, 0.7) 1px, transparent 1px),
                    linear-gradient(135deg, #0a0e27 0%, #1a237e 50%, #283593 100%);
            background-size: 30px 30px, 30px 30px, cover;
        }

        /* 成功卡片：毛玻璃 + 霓虹发光边框 */
        .success-card {
            background: rgba(15, 23, 42, 0.7);
            padding: 50px 30px;
            border-radius: 20px;
            border: 1px solid rgba(0, 212, 255, 0.4);
            backdrop-filter: blur(12px);
            text-align: center;
            animation: fadeIn 0.6s ease forwards;
            max-width: 400px;
            width: 90%;
            box-shadow:
                    0 0 40px rgba(0, 212, 255, 0.2),
                    inset 0 0 20px rgba(0, 212, 255, 0.1);
        }

        /* 成功图标：科幻霓虹绿 + 发光效果 */
        .success-icon {
            width: 80px;
            height: 80px;
            line-height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2ed573, #1dd19f);
            margin: 0 auto 25px;
            font-size: 40px;
            color: #ffffff;
            box-shadow: 0 0 20px rgba(46, 213, 115, 0.8);
            animation: scaleIn 0.5s ease 0.2s forwards;
            opacity: 0;
        }

        /* 标题：霓虹荧光蓝 + 文字发光 */
        .success-title {
            font-size: 26px;
            color: #00d4ff;
            margin-bottom: 12px;
            font-weight: 600;
            text-shadow:
                    0 0 10px rgba(0, 212, 255, 0.8),
                    0 0 20px rgba(0, 212, 255, 0.5);
            letter-spacing: 1px;
        }

        /* 描述文字：淡蓝色科技感 */
        .success-desc {
            font-size: 16px;
            color: #80d8ff;
            margin-bottom: 35px;
            line-height: 1.6;
            text-shadow: 0 0 5px rgba(128, 216, 255, 0.3);
        }

        /* 返回按钮：统一科幻霓虹蓝渐变 + 发光交互 */
        .back-btn {
            display: inline-block;
            padding: 12px 35px;
            background: linear-gradient(90deg, #00d4ff 0%, #0099cc 100%);
            color: #0a0e27;
            text-decoration: none;
            border-radius: 50px;
            font-size: 16px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 0 15px rgba(0, 212, 255, 0.5);
            letter-spacing: 1px;
        }

        .back-btn:hover {
            background: linear-gradient(90deg, #00e5ff 0%, #00b3e6 100%);
            transform: translateY(-2px);
            box-shadow: 0 0 25px rgba(0, 212, 255, 0.8);
        }

        /* 淡入动画（保留原有逻辑，优化科幻感） */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* 图标缩放动画（保留原有逻辑） */
        @keyframes scaleIn {
            from { opacity: 0; transform: scale(0.5); }
            to { opacity: 1; transform: scale(1); }
        }
    </style>
</head>
<body>
<div class="success-card">
    <!-- 成功图标 -->
    <div class="success-icon">
        <i class="fas fa-check"></i>
    </div>
    <!-- 提示文字 -->
    <h2 class="success-title"><%= msg %> ✅</h2>
<!--    <p class="success-desc">账单已保存成功，快去查看吧~</p>-->
    <!-- 返回首页按钮 -->
    <a href="<%= url %>" class="back-btn">返回</a>
</div>
</body>
</html>